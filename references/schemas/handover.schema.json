{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/anomalyco/ai-handover/schemas/handover.schema.json",
  "title": "AI Handover v4.1 Execution Record",
  "description": "Validates the YAML frontmatter of AI handover execution records — IRON RULE #2 compliant",
  "type": "object",
  "required": [
    "handover_id",
    "prev_handover_id",
    "agent_id",
    "agent_role",
    "coding_agent",
    "model",
    "status",
    "branch",
    "files_modified",
    "verification",
    "next_action",
    "lock_files"
  ],
  "properties": {
    "handover_id": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}_\\d{6}_.+$",
      "description": "Format: YYYY-MM-DD_HHmmss_description"
    },
    "prev_handover_id": {
      "type": "string",
      "description": "Previous handover ID for chain continuity (IRON RULE #4). Must be 'init' for first record."
    },
    "agent_id": {
      "type": "string",
      "minLength": 1
    },
    "agent_role": {
      "type": "string",
      "enum": ["primary", "orchestrator", "worker", "reviewer", "validator"]
    },
    "coding_agent": {
      "type": "string",
      "minLength": 1
    },
    "model": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "idle",
        "in-progress",
        "needs-review",
        "ready-for-merge",
        "resolved",
        "blocked",
        "changes-requested",
        "cancelled"
      ]
    },
    "branch": {
      "type": "string",
      "minLength": 1,
      "description": "Current git branch name (IRON RULE #2)"
    },
    "handover_type": {
      "type": "string",
      "enum": ["handover", "progress", "decision"]
    },
    "task_type": {
      "type": "string",
      "enum": ["feature", "fix", "refactor", "docs", "research", "review"]
    },
    "confidence": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "task_description": {
      "type": "string"
    },
    "next_action": {
      "type": "string",
      "pattern": "@[a-zA-Z_]+",
      "description": "Specifies the next agent's action (IRON RULE #2). e.g. '@reviewer please review src/auth/session.ts:42-48'"
    },
    "started_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 date-time string"
    },
    "ended_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 date-time string"
    },
    "files_modified": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 0,
      "uniqueItems": true
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "lock_files": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "File lock declarations for parallel agent coordination (IRON RULE #6)"
    },
    "verification": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^.+:.+$",
        "description": "Format: cmd:status (e.g. npm run lint:pass)"
      },
      "minItems": 0
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["level", "description"],
        "properties": {
          "level": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "rejected_alternatives": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notify": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["to", "via", "message"],
        "properties": {
          "to": {
            "type": "string",
            "minLength": 1
          },
          "via": {
            "type": "string",
            "enum": ["slack", "discord", "inbox"]
          },
          "message": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "previous_status": {
      "type": "string",
      "description": "Previous lane status"
    },
    "commit": {
      "type": "string",
      "description": "Git commit hash"
    },
    "duration_s": {
      "type": "integer",
      "description": "Duration in seconds"
    },
    "task_id": {
      "type": "string",
      "description": "Task identifier"
    },
    "parent_plan": {
      "type": "string",
      "description": "Parent plan reference"
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Blocking issues"
    },
    "files_added": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "New files"
    },
    "files_deleted": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Deleted files"
    }
  },
  "additionalProperties": false
}
